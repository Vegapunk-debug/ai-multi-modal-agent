# --- LLM ---
GROQ_API_KEY=
# fallback if Groq rate-limits
GEMINI_API_KEY=

# --- STT ---
DEEPGRAM_API_KEY=
# --- TTS ---
# Edge TTS uses no key (free Microsoft endpoint)

# --- Runtime ---
TARGET_LANG=spanish        # spanish | hindi
USER_ID=demo-user
LOG_LEVEL=INFO
TRACES_DIR=./traces
DB_PATH=./tutor.sqlite

# --- Pipeline ---
LLM_MODEL=gemini-2.5-flash
LLM_PROVIDER=gemini        # groq | gemini
STT_MODEL=nova-3
STT_LANGUAGE=multi         # multi enables code-switch
VAD_AGGRESSIVENESS=2

# --- Server ---
HOST=0.0.0.0
PORT=8000
ALLOW_ORIGIN=http://localhost:3001
